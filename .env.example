# Database (required)
DB_DSN=postgres://appuser:apppassword@localhost:5432/appdb?sslmode=disable

# App
APP_HTTP_ADDR=:8080
APP_ENV=dev
PUBLIC_BASE_URL=https://gmcl.co.uk
PUBLIC_ALT_BASE_URL=https://www.gmcl.co.uk
SANCTIONS_BASE_URL=https://sanctions.gmcl.co.uk
SANCTIONS_EVIDENCE_DIR=/app/data/sanction-evidence
SANCTIONS_IMPORT_DIR=/app/data/sanction-imports
# Hard kill switch for every sanctions email path. Set to true on staging.
SANCTIONS_EMAIL_DISABLED=false

# Run migrations and seed on startup (set for local Docker)
MIGRATE=1
MIGRATE_DIR=/migrations
SEED=1
SEED_ADMIN_PASSWORD=admin123

# Captain session signing (required for captain flow)
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: SMTP for 2FA and magic link emails (leave unset in dev to log to stdout)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# Optional mailbox that receives replies to transactional messages.
# SMTP_REPLY_TO=matchreports@gtrmcrcricket.co.uk
# Optional: SES configuration set name for delivery/bounce/complaint events.
# SES_CONFIGURATION_SET=gmcl-captain-reports

# Optional: Amazon SES SNS bounce/complaint webhook.
# Configure the SNS HTTPS endpoint as:
# https://your-domain.example/webhooks/aws/ses?token=<same-token>
# SES_SNS_WEBHOOK_TOKEN=change-me
# SES_SNS_AUTO_CONFIRM=0

# Optional: HMAC secret for /internal/* endpoints (n8n)
# HMAC_SECRET=your-shared-secret

# Optional: OpenAI-backed narrative generation for AI Executive reports.
# If OPENAI_API_KEY is unset, reports still generate with deterministic narrative text.
# OPENAI_API_KEY=
# OPENAI_REPORT_MODEL=gpt-5.2
# OPENAI_CHAT_MODEL=gpt-5.6-terra
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# RULES_SOURCE_URL=https://www.gtrmcrcricket.co.uk/pages/rules-main-menu
# RULES_ASSISTANT_SECRET=replace-with-a-long-random-value
RULES_ASSISTANT_ENABLED=false

# League / Play-Cricket API (optional — for syncing fixtures and umpire prefill)
# PLAY_CRICKET_API_BASE_URL=https://your-league-api-host
# PLAY_CRICKET_API_KEY=
# PLAY_CRICKET_LEAGUE_ID=11685
# Path appended to base URL; {leagueId} and {date} are substituted (date default dd/MM/yyyy)
# PLAY_CRICKET_MATCHES_URL_TEMPLATE=/?league_id={leagueId}&match_date={date}
# PLAY_CRICKET_MATCH_DETAIL_URL_TEMPLATE=/api/v2/match_detail.json?match_id={matchId}
# PLAY_CRICKET_DATE_FORMAT=dd/MM/yyyy
# PLAY_CRICKET_AUTH_QUERY_PARAM=api_token
# PLAY_CRICKET_AUTH_HEADER=
# PLAY_CRICKET_HTTP_TIMEOUT_SEC=30

# Public published Google Sheet used for the 2026 starred-player list.
# STARRED_PLAYERS_CSV_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vS_jUUxFnK1V0zjnrHfIjp-MAEftFsjXrzjSj0hKBywU8T_r9KBQ8mmdo_agQp1BF5XEZC59-jIoILa/pub?gid=1336530032&single=true&output=csv
